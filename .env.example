# Environment
DEBUG=true
ENVIRONMENT=development

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite:///./scrapify.db
REDIS_URL=redis://localhost:6379/0

# Scraping
MAX_WORKERS=5
REQUEST_TIMEOUT=10
USER_AGENT=ScrAPIfY/1.0 (Product Positioning & Market Research Tool)
RESPECT_ROBOTS_TXT=true

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# NLP
SENTIMENT_MODEL=textblob
LANGUAGE=en

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scrapify.log

# Proxy Settings
USE_PROXY=false
PROXY_LIST=

# Browser Automation
SELENIUM_DRIVER=chrome
HEADLESS_BROWSER=true